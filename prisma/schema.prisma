generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(USER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isSuspended   Boolean   @default(false)
  orders        Order[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())
  products    Product[]
}

model Product {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  description   String
  price         Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)
  stock         Int       @default(0)
  images        String[]
  material      String?
  dimensions    Json?
  variants      Json?
  colors        Json?
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  isNew         Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  isSale        Boolean   @default(false)
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  reviews       Review[]
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@index([isFeatured, isArchived])
  @@index([isSale, isArchived])
  @@index([reviewCount(sort: Desc)])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    String
  avatar    String?
  rating    Int
  title     String
  comment   String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([author, productId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(12, 2)
  shippingAddress Json?
  paymentMethod   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  variant   String?

  @@index([orderId])
  @@index([productId])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  color     String?
  variant   String?

  @@unique([userId, productId, color, variant])
  @@index([userId])
  @@index([productId])
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}
